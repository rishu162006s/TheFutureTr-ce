# Sanskriti Intelligence Platform — Environment Config
# Rename this to .env.local for local development

# Backend
DEBUG=true
SECRET_KEY=sanskriti-dev-secret-change-in-production
DATABASE_URL=sqlite+aiosqlite:///./sanskriti.db

# Embedding Model (runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Signal Scoring Weights
NOVELTY_WEIGHT=0.30
VELOCITY_WEIGHT=0.25
CREDIBILITY_WEIGHT=0.25
CROSS_SOURCE_WEIGHT=0.20

# Fix #9: Frontend API URL — points to FastAPI on port 8010
# In development: Next.js runs on :3000, backend on :8010
# In production: both served from :8010 (leave empty or remove)
NEXT_PUBLIC_API_URL=http://localhost:8010
